# .env  — never commit this file. Copy to .env and fill in real values.

# ── LLM narration backend (pluggable: gemini | ollama | huggingface) ────────
BTC_LLM_BACKEND=gemini
GEMINI_API_KEY=your-free-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
HF_TOKEN=your-free-huggingface-token-here
HF_MODEL=moonshotai/Kimi-K2-Instruct-0905

# ── BigQuery ──────────────────────────────────────────────────────────────
BIGQUERY_PROJECT_ID=your-free-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=C:\btc-intel\gcp-service-account.json

# ── PostgreSQL (runs natively on the Windows host) ──────────────────────────
POSTGRES_URI=postgresql://btcintel:CHANGE_ME@localhost:5432/btcintel

# ── Neo4j Community (runs natively on the Windows host) ─────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# ── MinIO (runs natively on the Windows host) ───────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=btcintel
MINIO_SECRET_KEY=CHANGE_ME

# ── Redis (runs natively on the Windows host) ───────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Seed sources ─────────────────────────────────────────────────────────────
CHAINABUSE_KEY=your-free-chainabuse-key
MISTTRACK_API_KEY=your-free-misttrack-key
